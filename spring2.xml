<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="
http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- SBU Bean -->
    <bean id="sbu1" class="com.demos.springcoree.beans.SBU">
        <property name="sbuId" value="10"/>
        <property name="sbuName" value="Product Engineering Services"/>
        <property name="sbuHead" value="Kiran Rao"/>
    </bean>

    <!-- Employee Bean -->
    <bean id="emp1" class="com.demos.springcoree.beans.Employee">

        <property name="employeeId" value="101"/>
        <property name="employeeName" value="Shruti"/>
        <property name="salary" value="50000"/>
        <property name="age" value="22"/>

        <!-- Injecting SBU Object -->
        <property name="businessUnit" ref="sbu1"/>

    </bean>

</beans>