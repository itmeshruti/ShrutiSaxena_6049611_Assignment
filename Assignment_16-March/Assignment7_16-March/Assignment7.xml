<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="http://www.springframework.org/schema/beans
 http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- SBU Bean -->


    <!-- Employee Bean -->

  <bean id="emp1" class="Assignment7.Employee">

        <property name="employeeId" value="101"/>
        <property name="employeeName" value="Ayush"/>
        <property name="salary" value="50000"/>
        <property name="businessUnit" value="IT"/>
        <property name="age" value="25"/>

    </bean>
    <bean id="emp2" class="Assignment7.Employee">

        <property name="employeeId" value="102"/>
        <property name="employeeName" value="Kartik"/>
        <property name="salary" value="50000"/>
        <property name="businessUnit" value="CS"/>
        <property name="age" value="26"/>

    </bean>
    
    

<bean id="sbu" class="Assignment7.SBU">

    <property name="sbuId" value="101"/>
        <property name="sbuHead" value="Mr. Raj"/>
        <property name="sbuName" value="Product Engineering"/>

    <property name="empList">
        <list>
            <ref bean="emp1"/>
            <ref bean="emp2"/>
        </list>
    </property>

</bean>

</beans>