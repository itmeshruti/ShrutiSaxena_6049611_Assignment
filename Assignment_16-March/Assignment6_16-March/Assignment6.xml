<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="http://www.springframework.org/schema/beans
 http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- SBU Bean -->

    <bean id="sbu" class="Assignment6.SBU">

        <property name="sbuId" value="101"/>
        <property name="sbuHead" value="Mr. Raj"/>
        <property name="sbuName" value="Product Engineering"/>

    </bean>

    <!-- Employee Bean -->

    <bean id="emp" class="Assignment6.UpdatedEmployee">

        <property name="employeeId" value="101"/>
        <property name="employeeName" value="Ayush"/>
        <property name="salary" value="50000"/>
        <property name="age" value="25"/>
        <property name="sbu" ref="sbu"/>

    </bean>

</beans>