package com.example.demo.service;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import com.example.demo.model.Product;
import com.example.demo.model.ProductCatalog;

@Service
public class CatalogService {

    @Autowired
    private RestTemplate restTemplate;

    public ProductCatalog getCatalog(Long pid) {

        Product product = restTemplate.getForObject(
                "http://localhost:8081/products/" + pid, Product.class);

        Price price = restTemplate.getForObject(
                "http://localhost:8082/price/" + pid, Price.class);

        Inventory inventory = restTemplate.getForObject(
                "http://localhost:8083/inventory/" + pid, Inventory.class);

        ProductCatalog pc = new ProductCatalog();
        pc.setPid(product.getPid());
        pc.setPname(product.getPname());
        pc.setPcategory(product.getPcategory());
        pc.setDiscountedPrice(price.getOfferPrice());
        pc.setNoOfItems(inventory.getNoOfItemsLeft());

        return pc;
    }
}