
spring.application.name=API-GATEWAY
server.port=9090

# Eureka
eureka.client.service-url.defaultZone=http://localhost:8761/eureka/

# Enable auto routing via Eureka
spring.cloud.gateway.discovery.locator.enabled=true
spring.cloud.gateway.discovery.locator.lower-case-service-id=true


# ---------------- ROUTES ----------------

# CART
spring.cloud.gateway.routes[0].id=CART
spring.cloud.gateway.routes[0].uri=lb://CART
spring.cloud.gateway.routes[0].predicates[0]=Path=/carts/**

# PRODUCT CATALOG
spring.cloud.gateway.routes[1].id=PRODUCTCATALOG
spring.cloud.gateway.routes[1].uri=lb://PRODUCTCATALOG
spring.cloud.gateway.routes[1].predicates[0]=Path=/catalogs/products/**

# PRODUCT SERVICE
spring.cloud.gateway.routes[2].id=PRODUCT
spring.cloud.gateway.routes[2].uri=lb://PRODUCT
spring.cloud.gateway.routes[2].predicates[0]=Path=/products/**

# PRICE SERVICE
spring.cloud.gateway.routes[3].id=PRICE
spring.cloud.gateway.routes[3].uri=lb://PRICE
spring.cloud.gateway.routes[3].predicates[0]=Path=/prices/**

# INVENTORY SERVICE
spring.cloud.gateway.routes[4].id=INVENTORY
spring.cloud.gateway.routes[4].uri=lb://Inventory
spring.cloud.gateway.routes[4].predicates[0]=Path=/inventory/**

# RECOMMENDATION SERVICE
spring.cloud.gateway.routes[5].id=RECOMMENDATION
spring.cloud.gateway.routes[5].uri=lb://RECOMMENDATION
spring.cloud.gateway.routes[5].predicates[0]=Path=/recommendations/**