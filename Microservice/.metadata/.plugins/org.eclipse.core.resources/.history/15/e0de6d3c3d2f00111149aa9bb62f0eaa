package com.example.demo.service;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import com.example.demo.model.Inventory;
import com.example.demo.model.Price;
import com.example.demo.model.Product;
import com.example.demo.model.ProductCatalog;

@Service
public class CatalogService {

    @Autowired
    private RestTemplate restTemplate;

    public ProductCatalog get(Long pid) {

        Product p = restTemplate.getForObject("http://localhost:8081/products/" + pid, Product.class);
        Price pr = restTemplate.getForObject("http://localhost:8082/price/" + pid, Price.class);
        Inventory inv = restTemplate.getForObject("http://localhost:8083/inventory/" + pid, Inventory.class);

        ProductCatalog pc = new ProductCatalog();
        pc.setPid(p.getPid());
        pc.setPname(p.getPname());
        pc.setPcategory(p.getPcategory());
        pc.setDiscountedPrice(pr.getOfferPrice());
        pc.setNoOfItems(inv.getNoOfItemsLeft());

        return pc;
    }
}