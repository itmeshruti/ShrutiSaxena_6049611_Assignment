package com.example.demo.service;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import com.example.demo.model.Cart;
import com.example.demo.model.ProductCatalog;
import com.example.demo.repository.CartRepository;

import io.github.resilience4j.circuitbreaker.annotation.CircuitBreaker;

@Service
public class CartService {

    @Autowired
    private CartRepository repo;

    @Autowired
    private RestTemplate restTemplate;

    // ✅ IMPORTANT: Use UPPERCASE service names (Eureka)
    private final String CATALOG = "http://ProductCatalog/catalogs/products/";
    private final String RECOMMEND = "http://Recommendation/recommendations";

    // =====================================================
    // 🔥 ADD TO CART
    // =====================================================
    public Map<String, Object> add(Long cartId, Long pid) {

        Cart cart = repo.findById(cartId).orElse(new Cart());
        cart.setCartId(cartId);

        // ✅ Circuit Breaker call
        ProductCatalog pc = getProduct(pid);

        // 🔹 Add to cart
        cart.getProducts().put(pid, pc.getPname());
        repo.save(cart);

        // 🔹 Prepare pid list
        List<Long> pids = new ArrayList<>(cart.getProducts().keySet());

        // ✅ Recommendation with CB
        ProductCatalog[] rec = getRecommendations(pids);

        // 🔹 Response
        Map<String, Object> res = new HashMap<>();
        res.put("message", "Product added to cart");
        res.put("recommendedItems", Arrays.asList(rec));

        return res;
    }

    // =====================================================
    // 🔥 GET CART
    // =====================================================
    public List<ProductCatalog> get(Long cartId) {

        Cart cart = repo.findById(cartId).orElse(null);
        List<ProductCatalog> cartItems = new ArrayList<>();

        if (cart != null) {
            for (Long pid : cart.getProducts().keySet()) {
                cartItems.add(getProduct(pid)); // CB used
            }
        }

        return cartItems;
    }

    // =====================================================
    // 🔥 CIRCUIT BREAKER METHODS
    // =====================================================

    // ✅ PRODUCT CATALOG CALL
    @CircuitBreaker(name = "catalogService", fallbackMethod = "catalogFallback")
    public ProductCatalog getProduct(Long pid) {

        ProductCatalog pc = restTemplate.getForObject(
                CATALOG + pid,
                ProductCatalog.class
        );

        // 🔥 Force CB if null
        if (pc == null) {
            throw new RuntimeException("Catalog returned null");
        }

        return pc;
    }

    // 🔻 FALLBACK FOR PRODUCT
    public ProductCatalog catalogFallback(Long pid, Throwable ex) {

        System.out.println("🔥 FALLBACK (Catalog): " + ex.getMessage());

        ProductCatalog pc = new ProductCatalog();
        pc.setPid(pid);
        pc.setPname("Fallback Product");
        pc.setPcategory("Service Down");

        return pc;
    }

    // =====================================================

    // ✅ RECOMMENDATION CALL
    @CircuitBreaker(name = "recommendService", fallbackMethod = "recommendFallback")
    public ProductCatalog[] getRecommendations(List<Long> pids) {

        ProductCatalog[] res = restTemplate.postForObject(
                RECOMMEND,
                pids,
                ProductCatalog[].class
        );

        if (res == null) {
            throw new RuntimeException("Recommendation failed");
        }

        return res;
    }

    // 🔻 FALLBACK FOR RECOMMENDATION
    public ProductCatalog[] recommendFallback(List<Long> pids, Throwable ex) {

        System.out.println("🔥 FALLBACK (Recommendation): " + ex.getMessage());

        ProductCatalog dummy = new ProductCatalog();
        dummy.setPid(0L);
        dummy.setPname("No Recommendations Available");
        dummy.setPcategory("N/A");

        return new ProductCatalog[]{dummy};
    }
}