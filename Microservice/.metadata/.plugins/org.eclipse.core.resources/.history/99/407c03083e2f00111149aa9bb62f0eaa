package com.example.demo.service;

import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import com.example.demo.model.Cart;
import com.example.demo.model.ProductCatalog;
import com.example.demo.repository.CartRepository;

@Service
public class CartService {

    @Autowired
    private CartRepository repo;

    @Autowired
    private RestTemplate restTemplate;

    // ✅ ADD TO CART
    public Cart add(Long cartId, Long pid) {

        Cart cart = repo.findById(cartId).orElse(new Cart());
        cart.setCartId(cartId);

        // 🔹 Get product details from Catalog Service
        ProductCatalog pc = restTemplate.getForObject(
                "http://localhost:8084/catalogs/products/" + pid,
                ProductCatalog.class
        );

        // 🔹 Safety check
        if (pc == null) {
            return cart;
        }

        // 🔹 Store in Map (pid → pname)
        cart.getProducts().put(pid, pc.getPname());

        return repo.save(cart);
    }

    // ✅ GET CART + RECOMMENDATIONS
    public Map<String, Object> get(Long cartId) {

        Cart cart = repo.findById(cartId).orElse(null);

        // 🔹 If cart not found
        if (cart == null) {
            Map<String, Object> emptyRes = new HashMap<>();
            emptyRes.put("cartItems", new ArrayList<>());
            emptyRes.put("recommendedItems", new ArrayList<>());
            return emptyRes;
        }

        // 🔹 Extract product IDs
        List<Long> pids = new ArrayList<>(cart.getProducts().keySet());

        // 🔹 Fetch Cart Items from Catalog Service
        List<ProductCatalog> cartItems = new ArrayList<>();
        for (Long pid : pids) {
            ProductCatalog pc = restTemplate.getForObject(
                    "http://localhost:8084/catalogs/products/" + pid,
                    ProductCatalog.class
            );
            if (pc != null) {
                cartItems.add(pc);
            }
        }

        // 🔹 Call Recommendation Service
        List<Integer> temp = restTemplate.postForObject(
                "http://localhost:8086/recommendations",
                pids,
                List.class
        );

        // 🔹 Convert Integer → Long
        List<Long> recIds = new ArrayList<>();
        if (temp != null) {
            for (Integer i : temp) {
                recIds.add(i.longValue());
            }
        }

        // 🔹 Fetch Recommended Items
        List<ProductCatalog> recItems = new ArrayList<>();
        for (Long pid : recIds) {
            ProductCatalog pc = restTemplate.getForObject(
                    "http://localhost:8084/catalogs/products/" + pid,
                    ProductCatalog.class
            );
            if (pc != null) {
                recItems.add(pc);
            }
        }

        // 🔹 Final Response
        Map<String, Object> res = new HashMap<>();
        res.put("cartItems", cartItems);
        res.put("recommendedItems", recItems);

        return res;
    }
}